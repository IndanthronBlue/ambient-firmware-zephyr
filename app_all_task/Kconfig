mainmenu "app_all_task"

source "Kconfig.zephyr"

menu "app_all_task feature switches"

config APP_LOW_POWER_FSM
	bool "Enable low-power FSM framework"
	default n
	help
	  Enable low-power state-machine integration paths.

config APP_DEEP_SLEEP_ENABLE
	bool "Enable deep-sleep entry paths"
	default n
	help
	  Enable real deep-sleep/standby entry logic.

config APP_RETENTION_ENABLE
	bool "Enable retained RAM features"
	default n
	help
	  Enable retained RAM based state persistence.

config APP_DEEP_SLEEP_SIMULATE
	bool "Simulate deep sleep for debug"
	default n
	help
	  Keep low-power flow testable on platforms where true standby is
	  unavailable during bring-up.

config APP_MICROPHONE_DEBUG_SKIP_GPS_LORA
	bool "Microphone debug: skip real GPS and LoRa operations"
	default n
	help
	  Enable this while debugging the microphone/codec path. GPS acquisition,
	  GPS power toggling, LoRaWAN join, and LoRaWAN uplink calls are skipped so
	  microphone tests are not blocked by radio/GNSS hardware behavior.

config APP_STATUS_LED
	bool "Enable low-power managed status LED"
	default y
	help
	  Enable short, event-driven LED pulses. The LED is forced off before
	  suspend/deep sleep and must not be used directly by feature tasks.

config APP_INFERENCE_LABEL_CNT
	int "Inference classifier label count"
	default 11
	range 1 254
	help
	  Number of classifier vocabulary labels. LoRa uplinks report this many
	  label count buckets plus one extra bucket for bird detections whose
	  confidence is below the threshold.

config APP_INFERENCE_LABELS_FILE
	string "Inference classifier label list file"
	default "config/inference_labels.txt"
	help
	  Text file containing one human-readable classifier label per line.
	  Relative paths are resolved from the application source directory.

config APP_INFERENCE_USE_INT16_QUANT_MODEL
	bool "Use int16 quantized inference model interface"
	default n
	help
	  Use int16_t fixed-point tensors for the generated Qualia model headers.
	  The application still computes MFCC features in float, then quantizes
	  them before model execution and dequantizes output logits for scoring.

config APP_MIC_MICPGA_GAIN_DB
	int "ADC3101 microphone PGA gain in dB"
	default 12
	range 0 40
	help
	  Analog microphone PGA gain applied to both ADC3101 channels. The codec
	  register uses 0.5 dB steps, so the integer dB value is written as
	  gain_db * 2.

config APP_LORAWAN_UPLINK_INTERVAL_MS
	int "LoRaWAN uplink interval"
	default 1800000
	range 1000 86400000
	help
	  Time window for one LoRaWAN telemetry packet. The default is 30 minutes.

config APP_INFERENCE_DETECT_CONF_THRESH_PERCENT
	int "Bird detector confidence threshold percent"
	default 50
	range 0 100
	help
	  Minimum small-model bird probability required before running the
	  classifier. Bird-positive detections below this threshold are counted in
	  the extra low-confidence bird uplink bucket.

config APP_GPS_UPLINK_WAIT_TIMEOUT_MS
	int "GPS wait timeout before LoRa uplink"
	default 30000
	range 0 300000
	help
	  Maximum time to wait for a GPS fix before sending the pending LoRa uplink
	  without fresh GPS data.

menu "Wakeup source switches"

config APP_WAKEUP_SRC_BUTTON
	bool "Enable button wakeup source"
	default y
	help
	  Allow button IRQ to wake the power FSM.

config APP_WAKEUP_SRC_PERIODIC
	bool "Enable periodic wakeup source"
	default y
	help
	  Allow periodic timer window to wake the power FSM.

config APP_WAKEUP_SRC_COMM
	bool "Enable comm wakeup source"
	default y
	help
	  Allow communication requests to wake the power FSM.

config APP_WAKEUP_SRC_RTC_ALARM
	bool "Enable RTC alarm wakeup source"
	default y
	help
	  Allow RTC alarm callback to wake the power FSM.

config APP_WAKEUP_SRC_SOUND
	bool "Enable sound IRQ wakeup source"
	default y
	help
	  Allow external sound IRQ to wake the power FSM.

config APP_WAKEUP_SRC_LOW_BAT
	bool "Enable low-battery wakeup source"
	default y
	help
	  Allow low-battery event to force transition into deep sleep.

config APP_GPS_LOCAL_TIME_OFFSET_HOURS
	int
	default 2
	range -12 14
	help
	  Deprecated compatibility option. RTC and retained GPS sync epochs stay
	  in UTC; audio storage paths also use UTC.

endmenu

endmenu
