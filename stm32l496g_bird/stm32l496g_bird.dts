/dts-v1/;
#include <st/l4/stm32l496Xg.dtsi>
#include <st/l4/stm32l496a(e-g)ix-pinctrl.dtsi>
#include "arduino_r3_connector.dtsi"
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/lora/sx126x.h>

/ {
	model = "LEAT STM32L496G-BIRD board";
	compatible = "leat,stm32l496g-bird";

	chosen {
		//zephyr,console = &usart2;
		//zephyr,shell-uart = &usart2;
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,flash-controller = &mx25r6435;
	};
	
	/* Custom pinctrl for SPI1 MISO with pull-up */
	soc {
		pinctrl: pin-controller@48000000 {
			spi1_miso_pb4_pullup: spi1_miso_pb4_pullup {
				pinmux = <STM32_PINMUX('B', 4, AF5)>;
				bias-pull-up;
			};
		};
	};
	

	leds {
		compatible = "gpio-leds";

		led: led {
			gpios = <&gpioc 8 GPIO_ACTIVE_HIGH>;
			label = "LED";
		};
	};

	gpio_keys {
		compatible = "gpio-keys";
		user_button: button {
			label = "User";
			gpios = <&gpioc 5 GPIO_ACTIVE_LOW>;
		};
		hall: hall {
			label = "Hall";
			gpios = <&gpioa 7 GPIO_ACTIVE_LOW>;
		};
        gps_main_power: gps_main_pwr {
            gpios = <&gpiob 11 GPIO_ACTIVE_HIGH>;
            label = "GPS Main Power";
        };
        gps_backup_power: gps_backup_pwr {
            gpios = <&gpiob 6 GPIO_ACTIVE_HIGH>;
            label = "GPS Backup Power";
        };
	};

	vbatt {
		compatible = "voltage-divider";
		io-channels = <&adc3 4>;
		output-ohms = <2000000>;
		full-ohms = <(1000000 + 2000000)>;
	};

	solar {
		compatible = "voltage-divider";
		io-channels = <&adc2 3>;
		output-ohms = <1000000>;
		full-ohms = <(4000000 + 1000000)>;
	};

	v_periph: v-periph-ctrl {
		compatible = "regulator-fixed";
		regulator-name = "v-periph";
		enable-gpios = <&gpioc 13 GPIO_ACTIVE_HIGH>;
		startup-delay-us = <2500>;
		regulator-boot-on;
	};

	aliases {
		led0 = &led;
		sw0 = &user_button;
		hall0 = &hall;
		mcuboot-led0 = &led;
		mcuboot-button0 = &user_button;
		gps-main-pwr = &gps_main_power;
        gps-backup-pwr = &gps_backup_power;
	};

	/* Custom pinctrl for SPI3 MISO with pull-up */
	soc {
		pinctrl: pin-controller@48000000 {
			spi3_miso_pc11_pullup: spi3_miso_pc11_pullup {
				pinmux = <STM32_PINMUX('C', 11, AF6)>;
				bias-pull-up;
			};
		};
	};
};

&clk_lsi {
	status = "okay";
};

&clk_hsi48 {
	status = "okay";
};

&clk_hsi {
	status = "okay";
};

&pll {
	div-m = <1>;
	mul-n = <20>;
	div-p = <7>;
	div-q = <2>;
	div-r = <4>;
	clocks = <&clk_hsi>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(80)>;
	ahb-prescaler = <1>;
	apb1-prescaler = <1>;
	apb2-prescaler = <1>;
};

&usart1 {
	pinctrl-0 = <&usart1_tx_pb6 &usart1_rx_pg10>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&usart2 {
	pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pd6>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&lpuart1 {
	pinctrl-0 = <&lpuart1_tx_pg7 &lpuart1_rx_pg8>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&timers2 {
	status = "okay";

	pwm2: pwm {
		status = "okay";
		pinctrl-0 = <&tim2_ch1_pa0>;
		pinctrl-names = "default";
	};
};

&i2c1 {
	//pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb7>;
	pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb9>;
	pinctrl-names = "default";
	scl-gpios = <&gpiob 8 (GPIO_OPEN_DRAIN | GPIO_ACTIVE_HIGH)>;
    sda-gpios = <&gpiob 9 (GPIO_OPEN_DRAIN | GPIO_ACTIVE_HIGH)>;
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;

	bme280: bme280@76 {
		compatible = "bosch,bme280";
		status = "okay";
		reg = <0x76>;
		vin-supply = <&v_periph>;
		zephyr,deferred-init;
	};

	cam_m8q: gps@10 {
        compatible = "u-blox,neo-m8"; 
        reg = <0x10>;
        status = "okay";
    };
};


&i2c2 {
	pinctrl-0 = <&i2c2_scl_pb13 &i2c2_sda_pb14>;
	pinctrl-names = "default";
	clocks = <&rcc STM32_CLOCK(APB1, 22)>,
		<&rcc STM32_SRC_HSI I2C2_SEL(2)>;
	clock-frequency = <I2C_BITRATE_STANDARD>;
	scl-gpios = <&gpiob 13 (GPIO_OPEN_DRAIN | GPIO_PULL_UP)>;
	sda-gpios = <&gpiob 14 (GPIO_OPEN_DRAIN | GPIO_PULL_UP)>;
	status = "okay";

	ina3221: ina3221@40 {
		compatible = "ti,ina3221";
		reg = <0x40>;
		shunt-resistors = <150 150 0>;
		enable-channel = <1 1 0>;
		conv-time-bus = <7>;
		conv-time-shunt = <7>;
		avg-mode = <2>;
		vin-supply = <&v_periph>;
		status = "okay";
	};
};

&spi3 {
	pinctrl-0 = <&spi3_sck_pc10 &spi3_miso_pc11_pullup &spi3_mosi_pc12>;
	cs-gpios = <&gpioc 0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>,
	           <&gpiod 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
	pinctrl-names = "default";
	status = "okay";

	lora: sx1262@0 {
		compatible = "semtech,sx1262";
		reg = <0>;
		label = "sx1262";
		reset-gpios = <&gpioa 4 GPIO_ACTIVE_LOW>;
		busy-gpios = <&gpiob 12 GPIO_ACTIVE_HIGH>;
		rx-enable-gpios = <&gpioc 4 GPIO_ACTIVE_LOW>;
		dio1-gpios = <&gpioc 7 GPIO_ACTIVE_HIGH>;
		dio2-tx-enable;
		dio3-tcxo-voltage = <SX126X_DIO3_TCXO_3V3>;
		tcxo-power-startup-delay-ms = <5>;
		spi-max-frequency = <1000000>;
		vin-supply = <&v_periph>;
	};

	sdhc0: sdhc@1 {
		compatible = "zephyr,sdhc-spi-slot";
		reg = <1>;
		status = "okay";
		/* Conservative SPI frequency to ensure reliable initialization */
		spi-max-frequency = <8000000>;
		/* Power delay for SD card initialization */
		power-delay-ms = <1500>;
		vin-supply = <&v_periph>;
		mmc {
			compatible = "zephyr,sdmmc-disk";
			disk-name = "SD";
			status = "okay";
		};
	};
};


&rtc {
	clocks = <&rcc STM32_CLOCK(APB1, 28)>,
		 <&rcc STM32_SRC_LSI RTC_SEL(2)>;
	status = "okay";
};

&sdmmc1 {
	pinctrl-0 = <&sdmmc1_d0_pc8 &sdmmc1_d1_pc9
		     &sdmmc1_d2_pc10 &sdmmc1_d3_pc11
		     &sdmmc1_ck_pc12 &sdmmc1_cmd_pd2>;
	pinctrl-names = "default";
	disk-name = "SD";
	status = "disabled";
};

&adc1 {
	pinctrl-0 = <&adc1_in10_pa5>;
	pinctrl-names = "default";
	st,adc-clock-source = "SYNC";
	st,adc-prescaler = <4>;
	status = "okay";
};

&adc2 {
	pinctrl-0 = <&adc2_in3_pc2>;
	pinctrl-names = "default";
	st,adc-clock-source = "SYNC";
	st,adc-prescaler = <4>;
	status = "okay";
};

&adc3 {
	pinctrl-0 = <&adc3_in4_pc3>;
	pinctrl-names = "default";
	st,adc-clock-source = "SYNC";
	st,adc-prescaler = <4>;
	st,adc-resolutions = <12 10 8 6>;
	sampling-times = <3 7 13 25 48 93 248 641>;
	st,adc-sequencer = "programmable";
	status = "okay";
};

&dma1 {
	status = "okay";
};

zephyr_udc0: &usbotg_fs {
	pinctrl-0 = <&usb_otg_fs_dm_pa11 &usb_otg_fs_dp_pa12 &usb_otg_fs_id_pa10>;
	pinctrl-names = "default";
	status = "okay";
};

&zephyr_udc0 {
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
};

&vref {
	status = "okay";
};

&vbat {
	status = "okay";
};

&dma2 {
	status = "okay";
};

&quadspi {
	pinctrl-0 = <&quadspi_bk1_io0_pb1 &quadspi_bk1_io1_pb0
		     &quadspi_bk1_io2_pa7 &quadspi_bk1_io3_pa6
		     &quadspi_bk1_ncs_pb11 &quadspi_clk_pa3>;
	pinctrl-names = "default";

	dmas = <&dma2 7 3 STM32_DMA_PERIPH_RX>; /* channel 7 request 3 on DMA2 */
	dma-names = "tx_rx";

	flash-id = <1>;
	status = "okay";

	mx25r6435: qspi-nor-flash@0 {
		compatible = "st,stm32-qspi-nor";
		reg = <0>;
		size = <DT_SIZE_M(64)>; /* 64 Mbits */
		qspi-max-frequency = <8000000>;
		cs-high-time = <3>; /* >= 30 ns */
		status = "okay";
		spi-bus-width = <4>;
		writeoc = "PP_1_4_4";
	};
};
